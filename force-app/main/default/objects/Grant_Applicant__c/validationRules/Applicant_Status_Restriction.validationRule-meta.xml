<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Applicant_Status_Restriction</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    $Profile.Name = &quot;Applicant Demo&quot;,
    NOT(ISPICKVAL(Application_Status__c, &quot;Submitted&quot;)),
NOT(ISPICKVAL(Application_Status__c, &quot;Withdrawn&quot;)),
    ISCHANGED(Application_Status__c)
)</errorConditionFormula>
    <errorMessage>You are only allowed to submit the application. Status changes beyond “Submitted” are restricted.</errorMessage>
</ValidationRule>
