<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Block_Finance_Approval_When_Deferred</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Approval_Type__c, &quot;Deferred&quot;),
  ISPICKVAL(Application_Status__c, &quot;Approved&quot;),
  $Profile.Name = &quot;Finance&quot;
)</errorConditionFormula>
    <errorMessage>This application is deferred by the Program Officer and cannot be approved by Finance.</errorMessage>
</ValidationRule>
