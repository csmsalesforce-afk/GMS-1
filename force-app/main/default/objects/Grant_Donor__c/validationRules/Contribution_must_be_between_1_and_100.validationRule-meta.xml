<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Contribution_must_be_between_1_and_100</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
    Contribution_Percentage__c &lt;= 0,
    Contribution_Percentage__c &gt; 100
)</errorConditionFormula>
    <errorMessage>Contribution must be between 1% and 100%.</errorMessage>
</ValidationRule>
