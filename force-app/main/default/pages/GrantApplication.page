<apex:page renderAs="pdf" showHeader="false" sidebar="false" applyHtmlTag="false" applyBodyTag="false" standardController="Grant_Applicant__c"> <html> <head> <style> body { font-family: Arial, Helvetica, sans-serif; font-size: 11px; color: #000; } .header { border-bottom: 2px solid #004B8D; padding: 5px 0 12px 0; margin-bottom: 20px; overflow: hidden; /* Prevent float overlap */ } .logo img{ max-height: 60px; } .logo{ float:left; } .title{ float:right; font-size:20px; font-weight:bold; color:#004B8D; margin-top:20px; } .section { margin-top: 20px; } .section-title { background-color: #004B8D; color: #fff; padding: 6px; font-weight: bold; } table { width: 100%; border-collapse: collapse; } td { padding: 6px; border: 1px solid #ccc; } .label { background-color: #f2f2f2; font-weight: bold; width: 30%; } .footer { margin-top: 30px; font-size: 9px; text-align: center; color: #666; } </style> </head> <body> <div class="header"> <div class="logo"> <img src="{!$Resource.InvoiceLogo}" width="140"/> </div> <div class="title"> Grant Application </div> </div> <div class="section"> <div class="section-title">Applicant Information</div> <table> <tr> <td class="label">Application Number</td> <td>{!Grant_Applicant__c.Name}</td> </tr> <tr> <td class="label">Applicant Name</td> <td>{!Grant_Applicant__c.Applicant_Name__c}</td> </tr> <tr> <td class="label">Application Status</td> <td>{!Grant_Applicant__c.Application_Status__c}</td> </tr> <tr> <td class="label">Region</td> <td>{!Grant_Applicant__c.Region__c}</td> </tr> <tr> <td class="label">Country</td> <td>{!Grant_Applicant__c.Country__c}</td> </tr> </table> </div> <div class="section"> <div class="section-title">Project Details</div> <table> <tr> <td class="label">Grant Program</td> <td>{!Grant_Applicant__c.Grant_Program__r.Name}</td> </tr> <tr> <td class="label">Project Title</td> <td>{!Grant_Applicant__c.Project_Title__c}</td> </tr> <tr> <td class="label">Project Description</td> <td>{!Grant_Applicant__c.Project_Description__c}</td> </tr> <tr> <td class="label">Start Date</td> <td> <apex:outputText value="{0,date,dd-MMM-yyyy}"> <apex:param value="{!Grant_Applicant__c.Start_Date__c}"/> </apex:outputText> </td> </tr> <tr> <td class="label">End Date</td> <td> <apex:outputText value="{0,date,dd-MMM-yyyy}"> <apex:param value="{!Grant_Applicant__c.End_Date__c}"/> </apex:outputText> </td> </tr> </table> </div> <div class="section"> <div class="section-title">Financial Summary</div> <table> <tr> <td class="label">Requested Amount</td> <td> <apex:outputText value="{0,number,currency}"> <apex:param value="{!Grant_Applicant__c.Requested_Amount__c}"/> </apex:outputText> </td> </tr> <tr> <td class="label">Submission Date</td> <td> <apex:outputText value="{0,date,dd-MMM-yyyy}"> <apex:param value="{!Grant_Applicant__c.Submission_Date__c}"/> </apex:outputText> </td> </tr> </table> </div> <div class="section"> <div class="section-title">Declaration</div> <p> I confirm that the information provided in this application is accurate and complete to the best of my knowledge. </p> </div> </body> </html> </apex:page>