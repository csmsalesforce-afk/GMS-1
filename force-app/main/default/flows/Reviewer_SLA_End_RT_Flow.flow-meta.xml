    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_SLA_End</targetReference>
        </connector>
        <filterLogic>(1 OR 2 )AND 3 AND 4</filterLogic>
        <filters>
            <field>Application_Status__c</field>
