    <decisions>
        <name>Evaluate_Alignment_Score</name>
        <label>Evaluate Alignment Score</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Do Nothing</defaultConnectorLabel>
        <rules>
            <name>Deferred</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Program_Alignment_Score__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>3.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Deferred</targetReference>
            </connector>
            <label>Deferred</label>
        </rules>
        <rules>
            <name>Conditional_Approval</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Program_Alignment_Score__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>3.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Program_Alignment_Score__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>4.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Conditional_Approval</targetReference>
            </connector>
            <label>Conditional Approval</label>
        </rules>
        <rules>
            <name>Full_Approval</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Program_Alignment_Score__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>5.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Full_Approval</targetReference>
            </connector>
            <label>Full Approval</label>
        </rules>
    </decisions>
